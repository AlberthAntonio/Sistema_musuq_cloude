# Configuración del Sistema Musuq Cloud
# Copia este archivo como .env y modifica los valores

# Información de la aplicación
APP_NAME=Sistema Musuq Cloud
DEBUG=true

# Base de datos
# Para desarrollo local con SQLite:
USE_SQLITE=true
SQLITE_URL=sqlite:///./musuq_dev.db

# Para PostgreSQL (cuando tengas instalado):
# USE_SQLITE=false
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/musuq_db

# JWT - Seguridad
# IMPORTANTE: Cambia esto en producción!
SECRET_KEY=tu-clave-secreta-super-segura-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Servidor
HOST=0.0.0.0
PORT=8000
