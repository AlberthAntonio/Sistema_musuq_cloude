# ============================================================
# .env.example - Template para PRODUCCIÓN
# Copiar a .env y ajustar valores antes de desplegar.
# NUNCA subir el .env real al repositorio.
# ============================================================
APP_NAME=Sistema Musuq Cloud
DEBUG=false

# ---- Base de datos PostgreSQL (producción) ----
USE_SQLITE=false
DATABASE_URL=postgresql://musuq_user:CAMBIAR_PASSWORD@localhost:5432/musuq_prod

# ---- JWT - Generar con: python -c "import secrets; print(secrets.token_hex(32))" ----
SECRET_KEY=CAMBIAR_CON_OPENSSL_RAND_HEX_32
REFRESH_SECRET_KEY=CAMBIAR_CON_OPENSSL_RAND_HEX_32_DIFERENTE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS - Poner las IPs del cliente desktop separadas por coma ----
# Ejemplo: ALLOWED_ORIGINS=http://192.168.1.10,http://192.168.1.20
ALLOWED_ORIGINS=http://192.168.1.10

# ---- Servidor ----
HOST=0.0.0.0
PORT=8000

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- Rate limiting ----
LOGIN_RATE_LIMIT=10
